# =============================================================================
# AlphaEta OpenClaw Agents - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to Git.
# =============================================================================

# --- Ollama (Local LLM) ---
OLLAMA_HOST=10.0.0.181
OLLAMA_PORT=11434

# --- Cloud API Fallbacks ---
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXX
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXX

# --- Gateway Security ---
OPENCLAW_GATEWAY_TOKEN=your-secure-gateway-token-here

# --- Josh (Research Agent) ---
JOSH_TELEGRAM_BOT_TOKEN=your-josh-telegram-bot-token
JOSH_GATEWAY_PORT=18789
JOSH_BRIDGE_PORT=18790

# --- Audrey (Schedule & Habits Agent) ---
AUDREY_TELEGRAM_BOT_TOKEN=your-audrey-telegram-bot-token
AUDREY_GATEWAY_PORT=18791
AUDREY_BRIDGE_PORT=18792
